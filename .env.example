# PRIMA – Environment Variables
# Set these in Vercel Dashboard → Settings → Environment Variables
# DO NOT commit a real .env file with values to git.

# ── AI Chatbot ──────────────────────────────────────────────────
# MiniMax API key for AI chatbot (https://MiniMax.ai)
MINIMAX_API_KEY=sk-cp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API key for AI chatbot (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Admin Data Editor (commit ke GitHub) ────────────────────────
# GitHub Personal Access Token (Settings → Developer settings → Personal access tokens → Fine-grained)
# Scope yang dibutuhkan: "Contents" → Read and write pada repo Prima-Rawajati.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Format: "owner/repo"
GITHUB_REPO=fareza777/Prima-Rawajati

# Branch tujuan commit (biasanya "main")
GITHUB_BRANCH=main

# Password kedua untuk akses endpoint /api/save-data
# Generate string acak panjang (32+ karakter). Cukup admin yang tahu.
ADMIN_SECRET=ganti-dengan-string-acak-panjang-32-karakter-atau-lebih

# ── Analytics Global (opsional) ─────────────────────────────────
# Agar Analytics Pengguna dihitung GLOBAL (semua pengunjung), bukan per-perangkat.
# Buat database gratis di https://upstash.com (Redis) lalu salin REST URL & Token.
# Kalau dua ini dikosongkan, analytics otomatis fallback ke hitungan lokal (per-perangkat).
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
